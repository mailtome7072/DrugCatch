# =============================================================================
# 애플리케이션 설정
# =============================================================================
DEBUG=false
SECRET_KEY=change-me-to-random-secret-key
JWT_SECRET=change-me-to-random-jwt-secret

# =============================================================================
# 데이터베이스 (PostgreSQL)
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=app_db
POSTGRES_USER=app_user
POSTGRES_PASSWORD=change-me-to-strong-password

# =============================================================================
# Redis
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# 프론트엔드
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# 외부 서비스 (프로젝트에 맞게 추가)
# =============================================================================
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# OTHER_API_KEY=
